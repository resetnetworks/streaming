{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/share.js": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/song/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": {
            "re": "(?i).*(bot|crawler|spider|facebookexternalhit|whatsapp|twitterbot|linkedinbot|telegrambot|discordbot|slackbot|applebot|chatgpt|openai|claude|cohere).*"
          }
        }
      ],
      "destination": "/api/share?type=song&id=:id"
    },
    {
      "source": "/album/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": {
            "re": "(?i).*(bot|crawler|spider|facebookexternalhit|whatsapp|twitterbot|linkedinbot|telegrambot|discordbot|slackbot|applebot|chatgpt|openai|claude|cohere).*"
          }
        }
      ],
      "destination": "/api/share?type=album&id=:id"
    },
    {
      "source": "/artist/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": {
            "re": "(?i).*(bot|crawler|spider|facebookexternalhit|whatsapp|twitterbot|linkedinbot|telegrambot|discordbot|slackbot|applebot|chatgpt|openai|claude|cohere).*"
          }
        }
      ],
      "destination": "/api/share?type=artist&id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}