{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "installCommand": "npm install --legacy-peer-deps",

  "functions": {
    "api/share.js": {
      "includeFiles": "dist/index.html"
    }
  },

  "rewrites": [
    {
      "source": "/album/:albumId",
      "destination": "/api/share?type=album&id=:albumId"
    },
    {
      "source": "/song/:songId",
      "destination": "/api/share?type=song&id=:songId"
    },
    {
      "source": "/artist/:artistId",
      "destination": "/api/share?type=artist&id=:artistId"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}